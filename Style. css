body { background: #1a1a1a; color: white; font-family: 'Courier New', monospace; text-align: center; }
#game-container { margin-top: 50px; border: 2px solid #444; padding: 20px; display: inline-block; }
button { background: #444; color: white; border: 1px solid #888; padding: 10px 20px; cursor: pointer; }
button:hover { background: #666; }
#hp { color: #ff4d4d; font-weight: bold; }
#mp { color: #4da6ff; font-weight: bold; }

